set scrolloff=5
" Do incremental searching.
set incsearch
" Don't use Ex mode, use Q for formatting.
map Q gq

" Keep lines centered
nmap <C-u> <C-u>zz
nmap <C-d> <C-d>zz
nmap n nzzzv
nmap N Nzzzv

" Yank binds
nmap <space>y "+y
vmap <space>y "+y
nmap <space>Y "+Y
xmap <leader>p "_dP
xmap <leader>P "_d"+P

" Insert mode movement
imap <C-l> <right>
imap <C-h> <left>
imap <C-j> <down>
imap <C-k> <up>
imap <C-b> <Esc>_i
imap <C-e> <End>
imap <A-;> <End>;
imap <A-,> <End>,

" Move text around
xmap A :s/$/ 
xmap H <gv 
xmap J :m '>+1<CR>gv=gv 
xmap K :m '<-2<CR>gv=gv
xmap L >gv

cmap <M-/> \/

" --- Enable IdeaVim plugins https://jb.gg/ideavim-plugins

" Highlight copied text
Plug 'machakann/vim-highlightedyank'
" Commentary plugin
Plug 'tpope/vim-commentary'

set number
set relativenumber

"" -- Map IDE actions to IdeaVim -- https://jb.gg/abva4t
"" Map \r to the Reformat Code action
nmap <space>fm <Action>(ReformatCode)
nnoremap zC :action CollapseRegionRecursively<CR>
nnoremap zO :action ExpandRegionRecursively<CR>
